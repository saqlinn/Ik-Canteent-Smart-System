# ============================================================
# IK Smart Canteen — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env to version control.

# ----------------------------------------------------------
# FIREBASE CONFIGURATION
# Source: Firebase Console → Project Settings → Your Apps → SDK setup
# ----------------------------------------------------------
VITE_FIREBASE_API_KEY="AIzaSy..."
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789012"
VITE_FIREBASE_APP_ID="1:123456789012:web:abc123..."

# ----------------------------------------------------------
# RAZORPAY CONFIGURATION
# Source: https://dashboard.razorpay.com → Settings → API Keys
# Use "rzp_test_..." for test mode, "rzp_live_..." for production
# ----------------------------------------------------------
VITE_RAZORPAY_KEY_ID="rzp_test_..."
